graph LR
    subgraph "Load Generator"
        V[🌐 vegeta<br/>50/s, 200/s, 500/s]
    end

    subgraph "Docker Host"
        subgraph "Nginx Reverse Proxy"
            NGINX[Nginx :80<br/>HTTP + Stream :5000]
        end

        subgraph "Web Tier (2 replicas)"
            WEB1[web-1 Apache/PHP :80]
            WEB2[web-2 Apache/PHP :80]
        end

        subgraph "DB Routing"
            NGINX -->|stream :5000| PB1[PgBouncer1 :6432]
            NGINX -->|stream :5000| PB2[PgBouncer2 :6432]
        end

        subgraph "Database HA"
            PB1 -->|pool| DB1[(db1 Patroni+PG<br/>PRIMARY :5432)]
            PB2 -->|pool| DB2[(db2 Patroni+PG<br/>REPLICA :5432)]
            DB1 <-->|Consul KV| CONSUL[Consul 3-node cluster]
            DB2 <-->|Consul KV| CONSUL
            DB2 -.->|streaming replication| DB1
        end

        subgraph "Redis Sentinel"
            WEB1 -->|sessions| SENTINEL[Sentinel 1-3]
            WEB2 -->|sessions| SENTINEL
            SENTINEL -->|monitor| REDIS[(Redis 1-3)]
        end
    end

    V -->|HTTP :80| NGINX
    NGINX -->|proxy| WEB1
    NGINX -->|proxy| WEB2
    WEB1 -->|DB_HOST=nginx:5000| NGINX
    WEB2 -->|DB_HOST=nginx:5000| NGINX

    style V fill:#43a047,color:#fff
    style NGINX fill:#1565c0,color:#fff
