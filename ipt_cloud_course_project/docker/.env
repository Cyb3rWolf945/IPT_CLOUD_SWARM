# ==========================================
# Docker Swarm Stack — Environment Variables
# Phase 2: Containerized HA Infrastructure
# ==========================================

# Network
OVERLAY_SUBNET=10.0.0.0/16

# PostgreSQL / Patroni
POSTGRES_VERSION=14
PG_DATA_DIR=/var/lib/postgresql/data
PG_BIN_DIR=/usr/lib/postgresql/14/bin
PATRONI_SCOPE=project_o_cluster
PATRONI_NAMESPACE=/db/

# Database credentials
DB_NAME=project_o
DB_USER=app_user
DB_PASS=app_password
REPLICATOR_PASS=replicator_pass

# Patroni REST API
PATRONI_RESTAPI_PORT=8008

# PgBouncer
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_RESERVE_POOL_SIZE=25
PGBOUNCER_ADMIN_USER=postgres

# Consul
CONSUL_DATACENTER=dc1
CONSUL_BOOTSTRAP_EXPECT=3

# Redis
REDIS_PASSWORD=redispass
REDIS_PORT=6379
SENTINEL_PORT=26379
SENTINEL_QUORUM=2
REDIS_MASTER_NAME=mymaster
SENTINEL_DOWN_AFTER=5000
SENTINEL_FAILOVER_TIMEOUT=30000

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASS=ipt_cloud_2026
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=gallery

# Netdata
NETDATA_PARENT_PORT=19999

# Loki
LOKI_PORT=3100
LOKI_RETENTION=168h

# Grafana
GRAFANA_PORT=3000

# App
DB_HOST=nginx
DB_PORT=5000
WS_HOST=nginx
WS_PORT=80
