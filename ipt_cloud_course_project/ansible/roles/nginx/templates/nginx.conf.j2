# Define o pool de servidores web para onde o tráfego será enviado
upstream backend_web {
    server 192.168.44.21:80; # VM web1
    server 192.168.44.22:80; # VM web2
}
upstream backend_ws {
    ip_hash; # Sticky sessions — same client always hits same backend
    server 192.168.44.21:8000; # VM web1 Ratchet
    server 192.168.44.22:8000; # VM web2 Ratchet
}

server {
    listen 80;
    server_name _; # Aceita qualquer domínio/IP

    location / {
        proxy_pass http://backend_web;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # WebSocket proxy — Nginx proxies WS connections to Ratchet backends
    location /ws/ {
        proxy_pass http://backend_ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }

    # Netdata monitoring dashboard — proxy to monitor1
    location /netdata/ {
        proxy_pass http://192.168.44.61:19999/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400s;
    }

    # Grafana dashboard — proxy to monitor1
    location /grafana/ {
        proxy_pass http://192.168.44.61:3000/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400s;
    }
}
