# Netdata Configuration — managed by Ansible
# Mode: {{ netdata_mode }}
# Host: {{ inventory_hostname }} ({{ ansible_host }})

[global]
    run as user = netdata
    hostname = {{ inventory_hostname }}

[web]
    # Bind to all interfaces so the parent can be reached via Nginx proxy
    bind to = 0.0.0.0

{% if netdata_mode == "parent" %}
[registry]
    # Parent node: registry enabled for multi-node dashboard
    enabled = yes
    registry to announce = http://192.168.44.61:19999
{% endif %}

[health]
    enabled = yes
    # Suppress alarms on agent nodes (centralized on parent)
    {% if netdata_mode == "agent" %}
    enabled = no
    {% endif %}
